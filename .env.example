# --- SaciERP API (placeholder until SaciERP team entrega URL/creds) ---
# Per docs/implementacion.md, base URL must remain parameterized — no
# hardcoded IPs/domains. Replace with the production URL once SaciERP
# publishes the final API documentation.
SACIERP_API_URL=http://localhost/saci_api_mock/
SACIERP_API_TOKEN=

# --- SuiteCRM API V8 OAuth2 client (firmas) ---
# Created during Sprint 2 A2 (client_id `meta-bridge` already exists; a
# `saci-bridge` client will be issued in a follow-up issue).
SUITECRM_BASE_URL=https://firmas.moacrm.com
SUITECRM_OAUTH_CLIENT_ID=
SUITECRM_OAUTH_CLIENT_SECRET=

# --- MariaDB OCI managed (database `saci_bridge`) ---
# Schema with the saci_outbox table is created in INF-1193.
DB_HOST=129.213.101.91
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=saci_bridge

# --- Server ---
# In production behind Apache reverse proxy, bind only to loopback so the
# bridge is not directly reachable on :3000 from the internet. Override to
# 0.0.0.0 only for local dev/testing.
HOST=127.0.0.1
PORT=3100
LOG_LEVEL=info
NODE_ENV=development
